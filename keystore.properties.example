# Copy this file to `keystore.properties` (git-ignored) and fill in your own
# signing credentials to build a signed Miru release APK.
#
# Generate a keystore once with:
#   keytool -genkey -v -keystore miru.keystore -alias miru \
#           -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=miru.keystore
storePassword=CHANGE_ME
keyAlias=miru
keyPassword=CHANGE_ME
